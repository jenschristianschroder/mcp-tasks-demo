{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "TasksDb": "Host=localhost;Database=tasks;Username=tasks;Password=<set-via-env>"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<set-via-env>",
    "ClientId": "<set-via-env>",
    "Audience": "api://<tasks-api-app-id>"
  }
}
