{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<set-via-env>",
    "ClientId": "<set-via-env>",
    "Audience": "api://<mcp-server-app-id>",
    "ClientCredentials": [
      {
        "SourceType": "SignedAssertionFromManagedIdentity",
        "ManagedIdentityClientId": "<set-via-env>"
      }
    ]
  },
  "DownstreamApi": {
    "BaseUrl": "https://<tasks-api-fqdn>",
    "Scopes": "api://<tasks-api-app-id>/Tasks.ReadWrite"
  }
}
